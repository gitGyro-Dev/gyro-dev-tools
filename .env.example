# GitHub API configuration
# Copy this file to .env and edit values as needed.

GITHUB_OWNER=gitGyro-Dev
GITHUB_REPO=gyro-dev-tools
GITHUB_BRANCH=main

# Do NOT write your token here if you do not want it stored in a file.
# Recommended: set GITHUB_TOKEN as an environment variable in PowerShell.
#
# PowerShell:
# $env:GITHUB_TOKEN="github_pat_xxxxx"
#
# Optional:
# GITHUB_TOKEN=github_pat_xxxxx